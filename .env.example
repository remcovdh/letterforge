# Copy this to .env and fill in the values you need.
# All variables are optional — only set what your chosen models require.

# OpenAI (DALL-E 3 image model, GPT-4o LLM)
OPENAI_API_KEY=sk-...

# Anthropic (Claude LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Google (Imagen image model, Gemini LLM)
GOOGLE_API_KEY=...
GOOGLE_CLOUD_PROJECT=my-gcp-project
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Ollama (local LLM — no key needed, just ensure the server is running)
# LETTERFORGE_OLLAMA__BASE_URL=http://localhost:11434
# LETTERFORGE_OLLAMA__MODEL=llama3

# ComfyUI (local image generation — no key needed)
# LETTERFORGE_COMFYUI__BASE_URL=http://localhost:8188

# Override default model selection
# LETTERFORGE_IMAGE_MODEL=dalle
# LETTERFORGE_LLM=claude

# Docker deployment: set this to the directory holding your input image + where output goes
# WORK_DIR=/home/you/my-project
